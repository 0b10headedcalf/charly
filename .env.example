# Copy to .env.local and fill in. The app runs in demo/mock mode with none of
# these set; each tier you add makes it more real.

# Tier 1 — REQUIRED for live AI: DigitalOcean serverless inference key.
# Console → INFERENCE → Manage → Create model access key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# Tier 2 — dedicated DO Agent Platform agents, one endpoint + key each.
# Create them with `node scripts/provision-do-agents.mjs` (needs
# DIGITALOCEAN_API_TOKEN) or by hand in the console (SETUP.md).
# Endpoints look like https://xxxxx.agents.do-ai.run (no trailing path).

# charli — member-facing persona
CHARLI_ENDPOINT=
CHARLI_KEY=
# planner — community organizing logistics (action plans), KB attached
PLANNER_ENDPOINT=
PLANNER_KEY=
# scout — org discovery/info + ops copilot, RAG over the orgs KB
SCOUT_ENDPOINT=
SCOUT_KEY=

# Auth (optional): GitHub OAuth app — callback URL is
# http://localhost:3000/api/auth/callback (github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# any long random string; guest sign-in works without it in dev
AUTH_SECRET=

# Optional model overrides (defaults shown)
# DO_CHAT_MODEL=anthropic-claude-4.6-sonnet
# DO_CLASSIFIER_MODEL=llama3.3-70b-instruct
