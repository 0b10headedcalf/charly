# Copy to .env.local and fill in. The app runs in demo/mock mode with none of
# these set; each tier you add makes it more real.

# Tier 1 — REQUIRED for live AI: DigitalOcean serverless inference key.
# Console → INFERENCE → Manage → Create model access key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# Tier 2 — optional: dedicated Charli agent (DO console → Agent Platform).
# Endpoint looks like https://xxxxx.agents.do-ai.run (no trailing path).
CHARLI_ENDPOINT=
CHARLI_KEY=

# Tier 2 — optional: Planner agent with the orgs knowledge base attached.
PLANNER_ENDPOINT=
PLANNER_KEY=

# Optional model overrides (defaults shown)
# DO_CHAT_MODEL=anthropic-claude-4.6-sonnet
# DO_CLASSIFIER_MODEL=llama3.3-70b-instruct
